<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FAFAFA"
        android:padding="16dp">

        <View
            android:id="@+id/viewLogoShimmer"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="#E0E0E0"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/viewSymbolShimmer"
            android:layout_width="64dp"
            android:layout_height="20dp"
            android:layout_marginStart="16dp"
            android:background="#E0E0E0"
            app:layout_constraintBottom_toTopOf="@+id/viewNameShimmer"
            app:layout_constraintStart_toEndOf="@+id/viewLogoShimmer"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed" />

        <View
            android:id="@+id/viewNameShimmer"
            android:layout_width="100dp"
            android:layout_height="14dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="6dp"
            android:background="#E0E0E0"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/viewLogoShimmer"
            app:layout_constraintTop_toBottomOf="@+id/viewSymbolShimmer" />

        <View
            android:id="@+id/viewPriceShimmer"
            android:layout_width="80dp"
            android:layout_height="20dp"
            android:background="#E0E0E0"
            app:layout_constraintBottom_toTopOf="@+id/viewChangeShimmer"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed" />

        <View
            android:id="@+id/viewChangeShimmer"
            android:layout_width="60dp"
            android:layout_height="16dp"
            android:layout_marginTop="6dp"
            android:background="#E0E0E0"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/viewPriceShimmer" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
